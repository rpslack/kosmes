# Firestore (default when credentials or FIRESTORE_ENABLED is set)
# Service account JSON path (recommended for local / cron):
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json

# Or on GCP with ADC and no JSON file:
# FIRESTORE_ENABLED=1

# Optional: collection name (default: te_commodity_quotes)
# FIRESTORE_COLLECTION=te_commodity_quotes

# Optional: also append CSV when writing to Firestore
# SAVE_CSV=1
